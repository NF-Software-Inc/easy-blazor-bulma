@page "/masonry-images"
@inherits ComponentBase

<TitleBlock Title="Masonry Image Gallery" />

<div class="container pt-3">
    <Panel Title="Masonry + Images (No Infinite Scroll)" Color="BulmaColors.Blue">
        <div class="mb-3">
            <ButtonBase class="is-small is-light" DisplayText="Refresh Layout" OnClick="@RefreshLayout" />
        </div>

        <Masonry @ref="_masonry" ColumnWidth="260" Gutter="12" PercentPosition="true">
            @foreach (var item in Items)
            {
                <MasonryItem style="width:260px;">
                    <div class="box p-2">
                        <figure class="image mb-2">
                            <img src="@item.ImageUrl" alt="@item.Title" style="width:100%;height:auto;display:block;" loading="lazy" />
                        </figure>
                        <p class="title is-6 mb-1">@item.Title</p>
                        <p class="is-size-7">@item.Description</p>
                    </div>
                </MasonryItem>
            }
        </Masonry>
    </Panel>
</div>

@code {
    private Masonry? _masonry;

    private static readonly List<DemoImageItem> Items =
    [
        new(1, "Beach Walk", "https://picsum.photos/id/10/420/300", "A simple image card inside a masonry item."),
        new(2, "Forest Path", "https://picsum.photos/id/20/420/520", "Different heights show the masonry flow naturally."),
        new(3, "City Lights", "https://picsum.photos/id/30/420/340", "No infinite scroll is used in this demo."),
        new(4, "Mountain View", "https://picsum.photos/id/40/420/560", "Cards are rendered as static content."),
        new(5, "Bridge", "https://picsum.photos/id/50/420/360", "Masonry keeps columns balanced."),
        new(6, "Desert", "https://picsum.photos/id/60/420/480", "Image and text can be mixed in each card."),
        new(7, "Morning Lake", "https://picsum.photos/id/70/420/320", "Useful for gallery-like layouts."),
        new(8, "Coastline", "https://picsum.photos/id/80/420/540", "Each item can have custom metadata."),
        new(9, "Night Sky", "https://picsum.photos/id/90/420/370", "Layout updates can be triggered manually.")
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _masonry != null)
            await _masonry.Layout();
    }

    private async Task RefreshLayout()
    {
        if (_masonry != null)
            await _masonry.Layout();
    }

    private sealed record DemoImageItem(int Id, string Title, string ImageUrl, string Description);
}
