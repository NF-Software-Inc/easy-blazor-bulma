@page "/masonry"
@inherits ComponentBase

<TitleBlock Title="Masonry Test" />

<div class="container pt-3">
    <Panel Title="Masonry + Optional Infinite Scroll" Color="BulmaColors.Blue">
        <div class="columns is-variable is-4 mb-3">
            <div class="column is-12-mobile is-8-tablet">
                <Panel class="mb-5 is-size-7" Title="Options" Color="BulmaColors.Turquoise">
                    <div class="columns is-multiline">
                        <div class="column is-12-mobile is-4-tablet">
                            <label class="label is-size-7" title="Fixed width in pixels for each masonry column.">Column Width (px)</label>
                            <InputNumber class="input" @bind-Value="MasonryColumnWidth" min="80" step="1" />
                        </div>

                        <div class="column is-12-mobile is-4-tablet">
                            <label class="label is-size-7" title="Animation duration for item movement when layout updates.">Transition (ms)</label>
                            <InputNumber class="input" @bind-Value="MasonryTransitionMs" min="0" step="25" />
                        </div>

                        <div class="column is-12-mobile is-4-tablet">
                            <label class="label is-size-7" title="Spacing in pixels between masonry items.">Gutter (px)</label>
                            <InputNumber class="input" @bind-Value="MasonryGutter" min="0" step="1" />
                        </div>
                        <div class="column is-12-mobile is-8-tablet">
                            <label class="label is-size-7" title="CSS selector used by Masonry to find items. Keep this aligned with the item class.">Item Selector</label>
                            <InputText class="input" @bind-Value="MasonryItemSelector" placeholder=".masonry-item" />
                            <p class="help">Default is <code>.masonry-item</code>. If this selector does not match item elements, layout will fail.</p>
                        </div>
                        <div class="column is-12-mobile is-4-tablet">
                            <div title="Places items left-to-right instead of top-to-bottom packing order." class="mb-3">
                                <InputSwitch class="is-small" @bind-Value="MasonryHorizontalOrder" Label="Horizontal Order" IsBoxed="false" />
                            </div>
                            <div title="Uses percentage-based positioning. Usually best for responsive layouts.">
                                <InputSwitch class="is-small" @bind-Value="MasonryPercentPosition" Label="Percent Position" IsBoxed="false" />
                            </div>
                        </div>
                        <div class="column is-12-mobile">
                            <div class="buttons mt-2 is-justify-content-center">
                                <button type="button" class="button is-link is-small" title="Apply current option values to Masonry" @onclick="ApplyMasonryOptions">Apply Options</button>
                            </div>
                        </div>
                    </div>
                </Panel>
            </div>

            <div class="column is-12-mobile is-4-tablet">
                <Panel class="is-size-7" Title="Actions" Color="BulmaColors.Turquoise">
                    <div class="is-flex is-justify-content-space-between is-align-items-center" style="gap:0.75rem;">
                        <div class="buttons mb-0">
                            <button type="button" class="button is-info" title="Recalculate item positions" @onclick="RefreshLayout">Refresh Layout</button>
                        </div>
                        <div title="Automatically loads more tiles when the sentinel enters the viewport.">
                            <InputSwitch @bind-Value="UseInfiniteScroll" Label="Infinite Scroll" IsBoxed="false" />
                        </div>
                    </div>
                    <div class="mt-3">
                        <label class="label is-size-7" title="How many records to fetch each time load-more is triggered.">Items Per Load</label>
                        <input class="input" type="number" min="1" step="1" @bind="ItemsPerLoad" />
                    </div>
                </Panel>
            </div>
        </div>

        <MasonryInfiniteScroll OnLoadMore="Load" IsEnabled="@UseInfiniteScroll">
            <Masonry @ref="MasonryElement"
                     ItemSelector="@MasonryItemSelector"
                     ColumnWidth="MasonryColumnWidth"
                     Gutter="MasonryGutter"
                     PercentPosition="MasonryPercentPosition"
                     HorizontalOrder="MasonryHorizontalOrder"
                     TransitionDuration="TimeSpan.FromMilliseconds(MasonryTransitionMs)">
                @foreach (var tile in Tiles)
                {
                    <MasonryItem style="@($"width:{MasonryColumnWidth}px;")">
                        <div class="box p-2">
                            <figure class="image mb-2" style="overflow:hidden; border-radius:0.5rem;">
                                <img src="@tile.ImageUrl" alt="@tile.Title" style="width:100%; height:auto; display:block;" loading="lazy" @onload="OnImageLoaded" />
                            </figure>
                            <p class="title is-6 mb-1">@tile.Title</p>
                            <p class="is-size-7">@tile.Description</p>
                        </div>
                    </MasonryItem>
                }
            </Masonry>
        </MasonryInfiniteScroll>

        @if (UseInfiniteScroll == false)
        {
            <div class="has-text-centered mt-4">
                <button type="button" class="button is-primary" @onclick="Load">Load More</button>
            </div>
        }
    </Panel>
</div>
